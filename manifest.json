{
    "name": "Maskify",
    "version": "0.0.0.1",
    "manifest_version": 3,
    "description": "An extension that helps you protect user privacy by replacing email addresses with fake ones.",
    "icons": {
      "16": "icons/maskify16x16.png",
      "32": "icons/maskify32x32.png",
      "48": "icons/maskify48x48.png",
      "128": "icons/maskify128x128.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
        "matches": [
          "<all_urls>"
        ],
        "js": ["lib/jquery.min.js","content-scripts/content.js"]
    }
  ]
}
