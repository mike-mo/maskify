{
    "name": "Maskify",
    "version": "1.0.0",
    "manifest_version": 3,
    "description": "An extension that helps you protect user privacy by replacing email addresses with fake ones.",
    "permissions": ["tabs", "storage"],
    "icons": {
      "16": "icons/maskify16x16.png",
      "32": "icons/maskify32x32.png",
      "48": "icons/maskify48x48.png",
      "128": "icons/maskify128x128.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/maskify32x32.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
        "matches": [
          "<all_urls>"
        ],
        "js": ["data/names-en.js", "data/names-es.js", "data/domain-utils.js", "content-scripts/content.js"]
    }
  ]
}
